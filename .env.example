# Environment Configuration for Playwright Tests
# Copy this file to .env and update with your actual values
# OrangeHRM Automation Suite

# Environment Type (development, staging, production)
NODE_ENV=staging

# Base URLs for different environments
DEV_BASE_URL=https://opensource-demo.orangehrmlive.com
STAGING_BASE_URL=https://opensource-demo.orangehrmlive.com
PROD_BASE_URL=https://opensource-demo.orangehrmlive.com

# API URLs for different environments
DEV_API_URL=https://opensource-demo.orangehrmlive.com/web/index.php/api/v2
STAGING_API_URL=https://opensource-demo.orangehrmlive.com/web/index.php/api/v2
PROD_API_URL=https://opensource-demo.orangehrmlive.com/web/index.php/api/v2

# Authentication Credentials (use secure methods in production)
# Development Environment
DEV_ADMIN_USERNAME=Admin
DEV_ADMIN_PASSWORD=admin123
DEV_TEST_USERNAME=Admin
DEV_TEST_PASSWORD=admin123

# Staging Environment (use environment variables in CI/CD)
STAGING_ADMIN_USERNAME=
STAGING_ADMIN_PASSWORD=

# Production Environment (use secure vault in CI/CD)
PROD_ADMIN_USERNAME=
PROD_ADMIN_PASSWORD=

# Test Configuration
CROSS_BROWSER_TESTING=false
MOBILE_TESTING=false
START_LOCAL_SERVER=false

# CI/CD Configuration
CI=false

# Browser Configuration
DEFAULT_BROWSER=chrome

# Test Data Configuration
TEST_EMAIL_DOMAIN=orangehrm.com
TEST_DATA_PREFIX=AutoTest

# Debugging and Reporting
DEBUG_MODE=false
VERBOSE_LOGGING=false
SCREENSHOT_MODE=on-failure
VIDEO_MODE=on-failure
TRACE_MODE=on-failure

# Timeout Configuration (in milliseconds)
NAVIGATION_TIMEOUT=60000
ELEMENT_TIMEOUT=30000
MANUAL_LOGIN_TIMEOUT=300000
FORM_SUBMISSION_TIMEOUT=60000

# Test Execution Configuration
MAX_RETRIES=2
PARALLEL_WORKERS=0
TEST_TIMEOUT=600000

# CI/CD Test Configuration
RUN_SMOKE_TESTS_ONLY=false
RUN_FULL_TEST_SUITE=true
